   - Incluir contexto suficiente para entender o erro
   - Usar emojis para facilitar identificação visual

2. **Níveis de Log**
   ```javascript
   // ✅ CORRETO - Usar níveis apropriados
   console.log('ℹ️ [INFO] Dados carregados:', data);
   console.warn('⚠️ [AVISO] Validação falhou:', errors);
   console.error('❌ [ERRO] Falha ao salvar:', error);
   console.debug('🔍 [DEBUG] Estado atual:', state);
   ```

3. **Estrutura de Mensagens**
   ```javascript
   // ✅ CORRETO - Formato padronizado
   console.log('📊 [OrganogramaCanvas] Renderizando', nodes.length, 'nós');
   console.error('❌ [API] Erro ao buscar órgão:', {
     orgao: nomeOrgao,
     erro: error.message,
     status: error.response?.status
   });
   
   // ❌ ERRADO - Mensagem vaga
   console.log('erro');
   console.log(error);
   ```

4. **Logging de Requisições API**
   ```javascript
   // ✅ SEMPRE logar requisições e respostas
   console.log('🌐 [API] GET /api/organogramas');
   console.log('✅ [API] Resposta recebida:', response.data);
   
   // Em caso de erro
   console.error('❌ [API] Erro na requisição:', {
     url: error.config?.url,
     method: error.config?.method,
     status: error.response?.status,
     mensagem: error.response?.data?.message || error.message
   });
   ```

5. **Logging de Validações**
   ```javascript
   // ✅ Logar validações que falharam
   console.warn('⚠️ [Validação] Regra DAS violada:', {
     setor: setor.nomeSetor,
     cargo: 'DAS-9',
     quantidadeTentada: 2,
     quantidadeMaxima: 1
   });
   ```

6. **Logging de Estado (React)**
   ```javascript
   // ✅ Logar mudanças de estado importantes
   useEffect(() => {
     console.log('🔄 [Estado] Organogramas atualizados:', {
       total: organogramas.length,
       orgaos: organogramas.map(o => o.orgao)
     });
   }, [organogramas]);
   ```

### Utilitário de Logging (Criar em utils/)

```javascript
// frontend/src/utils/logger.js

const COLORS = {
  info: '#2196F3',
  success: '#4CAF50',
  warning: '#FF9800',
  error: '#F44336',
  debug: '#9C27B0'
};

export const logger = {
  info: (component, message, data) => {
    console.log(
      `%cℹ️ [${component}] ${message}`,
      `color: ${COLORS.info}; font-weight: bold`,
      data || ''
    );
  },
  
  success: (component, message, data) => {
    console.log(
      `%c✅ [${component}] ${message}`,
      `color: ${COLORS.success}; font-weight: bold`,
      data || ''
    );
  },
  
  warn: (component, message, data) => {
    console.warn(
      `%c⚠️ [${component}] ${message}`,
      `color: ${COLORS.warning}; font-weight: bold`,
      data || ''
    );
  },
  
  error: (component, message, error) => {
    console.error(
      `%c❌ [${component}] ${message}`,
      `color: ${COLORS.error}; font-weight: bold`,
      {
        mensagem: error?.message,
        stack: error?.stack,
        detalhes: error?.response?.data
      }
    );
  },
  
  debug: (component, message, data) => {
    if (import.meta.env.DEV) {
      console.debug(
        `%c🔍 [${component}] ${message}`,
        `color: ${COLORS.debug}; font-weight: bold`,
        data || ''
      );
    }
  },
  
  api: {
    request: (method, url, data) => {
      console.log(
        `%c🌐 [API] ${method.toUpperCase()} ${url}`,
        'color: #00BCD4; font-weight: bold',
        data || ''
      );
    },
    
    response: (method, url, data) => {
      console.log(
        `%c✅ [API] Resposta ${method.toUpperCase()} ${url}`,
        'color: #4CAF50; font-weight: bold',
        data
      );
    },
    
    error: (method, url, error) => {
      console.error(
        `%c❌ [API] Erro ${method.toUpperCase()} ${url}`,
        'color: #F44336; font-weight: bold',
        {
          status: error.response?.status,
          mensagem: error.response?.data?.message || error.message,
          url: error.config?.url
        }
      );
    }
  }
};

// Uso:
// import { logger } from '../utils/logger';
// logger.info('OrganogramaCanvas', 'Componente montado');
// logger.api.request('GET', '/api/organogramas');
```

