{
  "name": "peo-installer",
  "version": "1.0.0",
  "description": "Sistema Profissional de Organogramas PMDC - Instalador Electron",
  "author": "Antigravity AI / PMDC",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.0.3",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "electron": "^25.3.0",
    "electron-builder": "^24.4.0"
  },
  "build": {
    "appId": "br.gov.pmdc.peo",
    "productName": "P.E.O - Criador de Organograma",
    "files": [
      "src/**/*",
      "bundled-backend/**/*",
      "bundled-frontend/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "bundled-backend/**/*",
      "bundled-frontend/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "P.E.O - Organogramas",
      "runAfterFinish": true,
      "perMachine": true
    },
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Office"
    }
  }
}
