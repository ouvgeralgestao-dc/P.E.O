# Variáveis de Ambiente - Backend Organogramas PMDC
# Renomeie este arquivo para .env e preencha os valores antes de rodar o projeto

# Porta do servidor (FIXA - Default: 6001)
PORT=6001

# Ambiente (development | production)
NODE_ENV=development

# Caminho para armazenamento de dados JSON
DATA_PATH=./data

# Chave secreta para JWT (IMPORTANTE: Alterar para uma chave forte em produção)
# Chave secreta para JWT (IMPORTANTE: Alterar para uma chave forte em produção)
JWT_SECRET=sua_chave_secreta_aqui_troque_isso_em_producao

# Configurações de E-mail (SMTP)
# Para Gmail: smtp.gmail.com | Porta: 587 (TLS) ou 465 (SSL)
# Use Senha de App (App Password) se usar 2FA
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app_aqui
