# Variáveis de Ambiente - Backend Organogramas PMDC

# Porta do servidor (FIXA - NÃO ALTERAR)
PORT=6000

# Ambiente (development | production)
NODE_ENV=development

# Caminho para armazenamento de dados JSON
DATA_PATH=./data

# Chave secreta para JWT (em produção usar uma chave forte e segura)
JWT_SECRET=sua_chave_secreta_muito_forte_aqui_trocar_em_producao
